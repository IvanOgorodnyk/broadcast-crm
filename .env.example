# ---- Database ----
# Postgres connection string (Neon, Supabase, Railway, local Postgres, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/broadcast_crm?schema=public"

# ---- Auth ----
# Secret used to sign session JWTs. Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# Base URL of the app (used for links in notifications / integrations)
APP_URL="http://localhost:3000"

# ---- Google Calendar integration (optional for MVP) ----
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/integrations/google/callback"

# ---- Telegram bot integration (optional for MVP) ----
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME=""
# Random string passed to Telegram's setWebhook as secret_token; the webhook
# route rejects updates without it.
TELEGRAM_WEBHOOK_SECRET=""

# ---- Cron (daily Telegram reminders) ----
# Random string; Vercel Cron authenticates to /api/cron/reminders with it.
CRON_SECRET=""
